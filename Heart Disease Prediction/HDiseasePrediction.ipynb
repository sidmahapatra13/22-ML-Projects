   "source": [
    "**Splitting the Features and Target**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "effe8510",
   "metadata": {},
   "outputs": [],
   "source": [
    "X = heart_df.drop(columns='target')\n",
    "y = heart_df['target']"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b1b6f653",
   "metadata": {},
   "source": [
    "**train_test_split**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "79cef450",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)"
   ]
  },
