   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "47fe8e60",
   "metadata": {},
   "outputs": [],
   "source": [
    "model = LogisticRegression()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a968bfbf",
   "metadata": {},
   "outputs": [],
   "source": [
    "#training the model with training data\n",
    "model.fit(X_train, y_train)"
   ]
